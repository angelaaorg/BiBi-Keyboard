  <!-- ============================================== -->
  <!-- Feature Descriptions for Input Settings -->
  <!-- ============================================== -->
  <!-- Trim trailing punctuation -->
  <string name="feature_trim_trailing_punct_off_desc">Recognition results will keep all content as is.</string>
  <string name="feature_trim_trailing_punct_on_desc">Recognition results within the threshold will remove trailing punctuation and emoji. Set the threshold to Unlimited to apply it to any length.</string>

  <!-- Mic haptic -->
  <string name="feature_mic_haptic_off_desc">No haptic feedback when pressing keys or interacting with the floating ball.</string>
  <string name="feature_mic_haptic_on_desc">Provides haptic feedback when pressing keys or interacting with the floating ball for better tactile experience.</string>

  <!-- Mic tap toggle -->
  <string name="feature_mic_tap_toggle_off_desc">Long-press the mic button to record, release to stop recording.</string>
  <string name="feature_mic_tap_toggle_on_desc">Tap the mic button to start recording, tap again to stop. Easier for one-handed operation.</string>

  <!-- Auto start recording on show -->
  <string name="feature_auto_start_recording_on_show_off_desc">You need to manually press the mic button to start recording after the keyboard appears.</string>
  <string name="feature_auto_start_recording_on_show_on_desc">Recording starts automatically when the keyboard appears, saving you one tap.</string>

  <!-- Fcitx5 return on switcher -->
  <string name="feature_fcitx5_return_on_switcher_off_desc">The IME switcher key opens the system input method picker.</string>
  <string name="feature_fcitx5_return_on_switcher_on_desc">The IME switcher key returns to the specified input method (falls back to the previous one if not set).</string>

  <!-- Return prev IME on hide -->
  <string name="feature_return_prev_ime_on_hide_off_desc">The current input method remains as BiBi Keyboard after hiding.</string>
  <string name="feature_return_prev_ime_on_hide_on_desc">Switches to the specified input method when the keyboard is hidden (falls back to the previous one if not set), convenient for temporary voice input.</string>

  <!-- Hide recent tasks -->
  <string name="feature_hide_recent_tasks_off_desc">The app card is visible in the recent tasks overview.</string>
  <string name="feature_hide_recent_tasks_on_desc">The app card is hidden from the recent tasks overview for a cleaner multitasking view. May reduce background keep-alive capability.</string>

  <!-- Duck media on record -->
  <string name="feature_duck_media_on_record_off_desc">Media playback volume remains unchanged during recording.</string>
  <string name="feature_duck_media_on_record_on_desc">Automatically pauses media playback during recording to reduce interference and improve recognition accuracy.</string>

  <!-- Offline denoise -->
  <string name="feature_auto_cancel_empty_audio_input_off_desc">Non-streaming recognition requests are sent even when the recording contains no detected speech.</string>
  <string name="feature_auto_cancel_empty_audio_input_on_desc">Uses the local VAD model before non-streaming recognition. If no speech is detected, the audio is not sent to the recognition provider.</string>
  <string name="feature_auto_filter_silent_audio_segments_off_desc">Non-streaming recognition uses the original recording, including silent pauses.</string>
  <string name="feature_auto_filter_silent_audio_segments_on_desc">Uses the local VAD model to remove silent parts before non-streaming recognition, reducing audio length and upload time.</string>

  <!-- Offline denoise -->
  <string name="feature_offline_denoise_off_desc">Raw audio is used without model-based denoise.</string>
  <string name="feature_offline_denoise_on_desc">Applies model-based denoise before non-streaming upload or offline recognition. Limited improvement for low-volume speech.</string>

  <!-- Upload audio compression -->
  <string name="feature_upload_audio_compression_off_desc">Non-streaming online recognition uploads uncompressed WAV audio. This can increase transfer size but avoids upload encoding work.</string>
  <string name="feature_upload_audio_compression_on_desc">Compresses audio before non-streaming online upload when the selected provider supports it, reducing transfer size and network time.</string>

  <!-- Headset mic priority -->
  <string name="feature_headset_mic_priority_off_desc">Uses the device\'s built-in microphone for recording.</string>
  <string name="feature_headset_mic_priority_on_desc">Prioritizes the headset microphone when available. Experimental feature, requires Bluetooth permission and nearby devices permission.</string>

  <!-- ============================================== -->
  <!-- Other Settings - Feature Explanations -->
  <!-- ============================================== -->

  <!-- Disable ASR history -->
  <string name="feature_disable_asr_history_off_desc">Recognition history will be saved for later review and management.</string>
  <string name="feature_disable_asr_history_on_desc">Recognition history will not be saved. Enabling this will clear all existing history. Use this to protect your privacy.</string>

  <!-- Disable usage statistics -->
  <string name="feature_disable_usage_stats_off_desc">Usage statistics (total characters and aggregated data) will be collected for your reference.</string>
