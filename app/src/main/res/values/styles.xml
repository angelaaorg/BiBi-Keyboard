<resources>

    <!-- ==================== 键盘样式 ==================== -->

    <!-- 键盘 ImageButton -->
    <style name="KeyboardImageButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_key_button</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:padding">6dp</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:stateListAnimator">@animator/key_button_state_list</item>
        <item name="android:tint">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- 键盘矩形按钮容器（中央状态显示区域） -->
    <style name="KeyboardRectContainer">
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_key_rect_button</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:stateListAnimator">@animator/key_button_state_list</item>
    </style>

    <!-- 数字/符号键：圆角矩形背景、40dp 高度、文字居中 -->
    <style name="NpKeyRect">
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_key_rect_button</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <!-- Ripple 已内置于背景，前景不再需要叠加 -->
        <item name="android:foreground">@null</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">18sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:padding">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>

    <!-- 录音手势按钮 -->
    <style name="KeyboardGestureButton">
        <item name="android:layout_width">86dp</item>
        <item name="android:layout_height">86dp</item>
        <item name="android:background">@drawable/bg_key_rect_button</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">14sp</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:clipToOutline">true</item>
    </style>

    <!-- 标点键视图 -->
    <style name="KeyboardPunctKey">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_key_button</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:stateListAnimator">@animator/key_button_state_list</item>
    </style>

    <!-- 数字键盘 ImageButton（用于底部功能按钮，无 ripple 前景） -->
    <style name="NpKeyImageButton">
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_key_rect_button</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:foreground">@null</item>
        <item name="android:padding">6dp</item>
        <item name="android:stateListAnimator">@animator/key_button_state_list</item>
        <item name="android:tint">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- ==================== 悬浮球样式 ==================== -->

    <!-- 悬浮球 ripple 动画视图 -->
    <style name="FloatingBallRipple">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:visibility">invisible</item>
        <item name="android:alpha">0</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
        <item name="android:importantForAccessibility">no</item>
    </style>

</resources>
