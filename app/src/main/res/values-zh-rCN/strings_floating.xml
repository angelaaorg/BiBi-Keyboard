    <!-- 悬浮球设置 - 功能说明 -->
    <!-- ============================================== -->

    <!-- 使用悬浮球进行语音识别 -->
    <string name="feature_floating_asr_off_desc">悬浮球将不会显示。语音识别只能通过键盘访问。</string>
    <string name="feature_floating_asr_on_desc">启用语音识别悬浮球。你可以在任何地方使用语音输入，即使键盘处于隐藏状态。需要悬浮窗和无障碍权限。</string>

    <!-- 仅在键盘显示时显示悬浮球 -->
    <string name="feature_floating_only_when_ime_visible_off_desc">即使键盘隐藏，悬浮球仍保持可见。</string>
    <string name="feature_floating_only_when_ime_visible_on_desc">键盘隐藏时悬浮球自动隐藏，键盘出现时自动显示。需要无障碍权限以检测键盘状态。</string>

    <!-- 直接拖动移动悬浮球 -->
    <string name="feature_floating_direct_drag_off_desc">移动悬浮球需要长按进入移动模式或通过菜单开启移动模式。</string>
    <string name="feature_floating_direct_drag_on_desc">可直接拖动悬浮球调整位置。</string>

    <!-- 音量键录音模式 -->
    <string name="feature_volume_key_recording_off_desc">音量键保持系统默认行为，不用于控制录音。</string>
    <string name="feature_volume_key_recording_on_desc">当键盘显示时，无障碍服务会监听音量键点击，用于开始或停止语音识别。不监听不稳定的音量键长按。</string>
    <string name="feature_volume_key_status_toast_off_desc">音量键录音开始和停止时不额外提示，现有错误提示不受影响。</string>
    <string name="feature_volume_key_status_toast_on_desc">使用音量键成功开始或停止录音时，显示短 Toast 提示。</string>
    <string name="feature_volume_key_stop_on_ime_hidden_off_desc">音量键录音期间如果键盘消失，录音会继续，直到你手动停止。</string>
    <string name="feature_volume_key_stop_on_ime_hidden_on_desc">音量键录音期间如果键盘消失，会自动停止录音。</string>

    <!-- 悬浮球写入文字兼容性模式 -->
    <string name="feature_floating_write_compat_off_desc">使用标准无障碍 API 插入文本。适用于大多数应用。</string>
    <string name="feature_floating_write_compat_on_desc">针对目标应用，使用"全选+粘贴"方法来避免背景占位符文本污染。可能会临时使用剪贴板（尽力恢复）。适用于 Telegram 和抖音等应用。</string>

    <!-- 悬浮球识别结果仅写入粘贴板 -->
    <string name="feature_floating_write_paste_off_desc">识别结果通过无障碍 API 直接插入到输入字段中。</string>
    <string name="feature_floating_write_paste_on_desc">针对目标包名，识别结果仅复制到剪贴板，不自动插入。适用于直接插入无法正常工作的应用。</string>

    <!-- 前台保活 -->
    <string name="feature_floating_keep_alive_off_desc">不开启前台服务，系统可能更容易回收后台进程。</string>
    <string name="feature_floating_keep_alive_on_desc">启动前台服务并显示常驻通知，强化后台保活能力。</string>
    <string name="feature_floating_keep_alive_privileged_off_desc">仍按常规方式启动前台保活服务，部分系统可能限制后台拉起。</string>
    <string name="feature_floating_keep_alive_privileged_on_desc">通过 Shizuku 或 root 定期以 shell 权限拉起前台保活服务，提高稳定性。需要 Shizuku 授权或 root。</string>
</resources>
