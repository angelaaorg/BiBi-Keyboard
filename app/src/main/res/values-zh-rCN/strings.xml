  <!-- 去除句末标点 -->
  <string name="feature_trim_trailing_punct_off_desc">识别结果保留所有内容。</string>
  <string name="feature_trim_trailing_punct_on_desc">短识别结果将自动去除句末标点和 emoji，超过阈值的长文本保留句末标点和 emoji。</string>

  <!-- 按键振动 -->
  <string name="feature_mic_haptic_off_desc">按下按键或操作悬浮球时没有振动反馈。</string>
  <string name="feature_mic_haptic_on_desc">按下按键或操作悬浮球时提供振动反馈，触感更好。</string>

  <!-- 点按控制 -->
  <string name="feature_mic_tap_toggle_off_desc">长按麦克风按钮开始录音，松开停止录音。</string>
  <string name="feature_mic_tap_toggle_on_desc">点击麦克风按钮开始录音，再次点击停止。方便单手操作。</string>

  <!-- 自动开始录音 -->
  <string name="feature_auto_start_recording_on_show_off_desc">键盘出现后需要手动按麦克风按钮开始录音。</string>
  <string name="feature_auto_start_recording_on_show_on_desc">键盘出现时自动开始录音，省去一次点击操作。</string>

  <!-- 输入法切换键功能 -->
  <string name="feature_fcitx5_return_on_switcher_off_desc">输入法切换键打开系统的输入法选择器。</string>
  <string name="feature_fcitx5_return_on_switcher_on_desc">输入法切换键直接返回指定输入法，未设置时返回上一个输入法。</string>

  <!-- 收起后切回上一个输入法 -->
  <string name="feature_return_prev_ime_on_hide_off_desc">键盘收起后，当前输入法仍为说点啥。</string>
  <string name="feature_return_prev_ime_on_hide_on_desc">键盘收起时自动切换到指定输入法，未设置时返回上一个输入法，方便临时语音输入。</string>

  <!-- 隐藏任务卡片 -->
  <string name="feature_hide_recent_tasks_off_desc">应用卡片在最近任务列表中可见。</string>
  <string name="feature_hide_recent_tasks_on_desc">应用卡片在最近任务列表中隐藏，多任务界面更清爽。可能会降低后台保活能力。</string>

  <!-- 录音时音频避让 -->
  <string name="feature_duck_media_on_record_off_desc">录音时媒体播放音量保持不变。</string>
  <string name="feature_duck_media_on_record_on_desc">录音时自动暂停媒体播放，减少干扰提高识别准确率。</string>

  <!-- 空音频检测与静音过滤 -->
  <string name="feature_auto_cancel_empty_audio_input_off_desc">非流式识别会照常发送录音，即使录音中没有检测到人声。</string>
  <string name="feature_auto_cancel_empty_audio_input_on_desc">非流式识别前使用本地 VAD 模型检测人声。没有检测到人声时，不向识别服务商发送本次音频。</string>
  <string name="feature_auto_filter_silent_audio_segments_off_desc">非流式识别使用原始录音，包含中间停顿和静音片段。</string>
  <string name="feature_auto_filter_silent_audio_segments_on_desc">非流式识别前使用本地 VAD 模型移除静音片段，缩短音频长度并减少上传时间。</string>

  <!-- 非流式降噪 -->
  <string name="feature_offline_denoise_off_desc">非流式上传或离线识别前不进行模型降噪。</string>
  <string name="feature_offline_denoise_on_desc">在非流式上传或离线识别前进行模型降噪，对低声说话改善有限。</string>

  <!-- 上传音频压缩 -->
  <string name="feature_upload_audio_compression_off_desc">在线非流式识别上传未压缩 WAV 音频，传输体积会增大，但不会进行上传前编码。</string>
  <string name="feature_upload_audio_compression_on_desc">在服务商支持时，在线非流式识别会在上传前压缩音频，减少传输体积和网络耗时。</string>

  <!-- 耳机麦克风优先 -->
  <string name="feature_headset_mic_priority_off_desc">使用设备内置麦克风进行录音。</string>
  <string name="feature_headset_mic_priority_on_desc">优先使用耳机麦克风（如果可用）。实验性功能，需要蓝牙权限和获取附近设备权限。</string>

