<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
      android:id="@+id/tvDialogTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="16dp"
      android:textAppearance="?attr/textAppearanceHeadlineSmall"
      android:textColor="?attr/colorOnSurface" />

    <TextView
      android:id="@+id/tvDialogEndpoint"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="12dp"
      android:textAppearance="?attr/textAppearanceTitleMedium"
      android:textColor="?attr/colorPrimary"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/tvDialogMeta"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="20dp"
      android:textAppearance="?attr/textAppearanceBodyMedium"
      android:textColor="?attr/colorOnSurfaceVariant" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/api_log_request"
      android:textAppearance="?attr/textAppearanceTitleSmall"
      android:textColor="?attr/colorOnSurface"
      android:layout_marginBottom="6dp" />

    <TextView
      android:id="@+id/tvDialogRequestValue"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="16dp"
      android:textAppearance="?attr/textAppearanceBodyLarge"
      android:textColor="?attr/colorOnSurface" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/api_log_request_structure"
      android:textAppearance="?attr/textAppearanceTitleSmall"
      android:textColor="?attr/colorOnSurface"
      android:layout_marginBottom="6dp" />

    <TextView
      android:id="@+id/tvDialogStructureValue"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="16dp"
      android:textAppearance="?attr/textAppearanceBodyLarge"
      android:textColor="?attr/colorOnSurface" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/api_log_response"
      android:textAppearance="?attr/textAppearanceTitleSmall"
      android:textColor="?attr/colorOnSurface"
      android:layout_marginBottom="6dp" />

    <TextView
      android:id="@+id/tvDialogResponseValue"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="16dp"
      android:textAppearance="?attr/textAppearanceBodyLarge"
      android:textColor="?attr/colorOnSurface" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/api_log_error"
      android:textAppearance="?attr/textAppearanceTitleSmall"
      android:textColor="?attr/colorOnSurface"
      android:layout_marginBottom="6dp" />

    <TextView
      android:id="@+id/tvDialogErrorValue"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="4dp"
      android:textAppearance="?attr/textAppearanceBodyLarge"
      android:textColor="?attr/colorError" />


  </LinearLayout>

</androidx.core.widget.NestedScrollView>
