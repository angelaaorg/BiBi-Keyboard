<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <com.google.android.material.appbar.MaterialToolbar
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:titleCentered="true"
    app:title="@string/title_input_settings" />

  <androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content">

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="@dimen/settings_form_max_width">

        <!-- 输入行为设置 -->
        <LinearLayout
          style="@style/SettingsSectionCard.First"
          android:orientation="vertical">

          <TextView
            style="@style/SettingsSectionCardTitle"
            android:text="@string/section_input_behavior" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchTrimTrailingPunct"
            style="@style/SettingsSwitch.First"
            android:layout_marginTop="0dp"
            android:text="@string/label_trim_trailing_punct" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchMicTapToggle"
            style="@style/SettingsSwitch"
            android:text="@string/label_mic_tap_toggle" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAutoStartRecordingOnShow"
            style="@style/SettingsSwitch"
            android:text="@string/label_auto_start_recording_on_show" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchHideRecentTasks"
            style="@style/SettingsSwitch"
            android:text="@string/label_hide_recent_task_card" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchFcitx5ReturnOnSwitcher"
            style="@style/SettingsSwitch"
            android:text="@string/label_fcitx5_return_on_switcher" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchReturnPrevImeOnHide"
            style="@style/SettingsSwitch"
            android:text="@string/label_return_prev_ime_on_hide" />

          <TextView
            style="@style/SettingsLabel"
            android:text="@string/label_ime_switch_target" />

          <TextView
            android:id="@+id/tvImeSwitchTargetValue"
            style="@style/SettingsClickableValue.Dropdown"
            android:text="@string/ime_switch_target_previous" />

        </LinearLayout>

        <!-- 音频和联动设置 -->
        <LinearLayout
          style="@style/SettingsSectionCard"
          android:orientation="vertical">

          <TextView
            style="@style/SettingsSectionCardTitle"
            android:text="@string/section_audio_and_link" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchDuckMediaOnRecord"
            style="@style/SettingsSwitch.First"
            android:layout_marginTop="0dp"
            android:text="@string/label_audio_ducking_on_record" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchOfflineDenoise"
            style="@style/SettingsSwitch"
            android:text="@string/label_offline_denoise" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchUploadAudioCompression"
            style="@style/SettingsSwitch"
            android:text="@string/label_upload_audio_compression" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchHeadsetMicPriority"
            style="@style/SettingsSwitch"
            android:text="@string/label_headset_mic_priority" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchExternalImeAidl"
            style="@style/SettingsSwitch"
            android:text="@string/label_external_ime_link_aidl" />

        </LinearLayout>

        <!-- UI设置 -->
        <LinearLayout
          style="@style/SettingsSectionCard"
          android:orientation="vertical">

          <TextView
            style="@style/SettingsSectionCardTitle"
            android:text="@string/section_ui_settings" />

          <!-- 键盘高度 -->
          <TextView
            style="@style/SettingsLabel"
            android:layout_marginTop="0dp"
            android:text="@string/label_keyboard_height" />

          <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleKeyboardHeight"
            style="@style/SettingsSegmentedButtonGroup">

            <Button
              android:id="@+id/btnHeightSmall"
              style="@style/SettingsSegmentedButton"
              android:text="@string/keyboard_height_small" />

            <Button
              android:id="@+id/btnHeightMedium"
              style="@style/SettingsSegmentedButton"
              android:text="@string/keyboard_height_medium" />

            <Button
              android:id="@+id/btnHeightLarge"
              style="@style/SettingsSegmentedButton"
              android:text="@string/keyboard_height_large" />

          </com.google.android.material.button.MaterialButtonToggleGroup>

          <!-- 触觉反馈强度 -->
          <TextView
            style="@style/SettingsLabel"
            android:text="@string/label_haptic_feedback_strength" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
              android:id="@+id/sliderHapticFeedbackStrength"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:valueFrom="0"
              android:valueTo="6"
              android:stepSize="1"
              android:value="1" />

            <TextView
              android:id="@+id/tvHapticFeedbackStrengthValue"
              style="@style/SettingsSliderValue"
              android:layout_width="wrap_content"
              android:minWidth="72dp"
              android:text="@string/haptic_strength_system" />

          </LinearLayout>

          <!-- 底部间距调节 -->
          <TextView
            style="@style/SettingsLabel"
            android:text="@string/label_keyboard_bottom_padding" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
              android:id="@+id/sliderBottomPadding"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:valueFrom="0"
              android:valueTo="100"
              android:stepSize="5"
              android:value="0" />

            <TextView
              android:id="@+id/tvBottomPaddingValue"
              style="@style/SettingsSliderValue"
              android:minWidth="48dp"
              android:text="0 dp" />

          </LinearLayout>

          <!-- 波形灵敏度 -->
          <TextView
            style="@style/SettingsLabel"
            android:text="@string/label_waveform_sensitivity" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
              android:id="@+id/sliderWaveformSensitivity"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:valueFrom="1"
              android:valueTo="10"
              android:stepSize="1"
              android:value="5" />

            <TextView
              android:id="@+id/tvWaveformSensitivityValue"
              style="@style/SettingsSliderValue"
              android:minWidth="24dp"
              android:text="5" />

          </LinearLayout>

          <!-- 界面语言 -->
          <TextView
            style="@style/SettingsLabel"
            android:text="@string/label_language" />

          <TextView
            android:id="@+id/tvLanguageValue"
            style="@style/SettingsClickableValue.Dropdown"
            android:text="@string/lang_follow_system" />

          <!-- 扩展按钮配置 -->
          <TextView
            style="@style/SettingsLabel"
            android:text="@string/label_extension_buttons" />

          <TextView
            android:id="@+id/tvExtensionButtonsValue"
            style="@style/SettingsClickableValue.Dropdown"
            android:text="@string/ext_btn_default_summary" />

        </LinearLayout>

      </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
  </androidx.core.widget.NestedScrollView>

</LinearLayout>
