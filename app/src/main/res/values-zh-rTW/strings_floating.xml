    <!-- 懸浮球設定 - 功能說明 -->
    <!-- ============================================== -->

    <!-- 使用懸浮球進行語音識別 -->
    <string name="feature_floating_asr_off_desc">懸浮球將不會顯示。語音識別只能透過鍵盤存取。</string>
    <string name="feature_floating_asr_on_desc">啟用語音識別懸浮球。你可以在任何地方使用語音輸入，即使鍵盤處於隱藏狀態。需要懸浮窗和無障礙權限。</string>

    <!-- 僅在鍵盤顯示時顯示懸浮球 -->
    <string name="feature_floating_only_when_ime_visible_off_desc">即使鍵盤隱藏，懸浮球仍保持可見。</string>
    <string name="feature_floating_only_when_ime_visible_on_desc">鍵盤隱藏時懸浮球自動隱藏，鍵盤出現時自動顯示。需要無障礙權限以偵測鍵盤狀態。</string>

    <!-- 直接拖動移動懸浮球 -->
    <string name="feature_floating_direct_drag_off_desc">移動懸浮球需要長按進入移動模式或透過選單開啟移動模式。</string>
    <string name="feature_floating_direct_drag_on_desc">可直接拖動懸浮球調整位置。</string>

    <!-- 音量鍵錄音模式 -->
    <string name="feature_volume_key_recording_off_desc">音量鍵保持系統預設行為，不用於控制錄音。</string>
    <string name="feature_volume_key_recording_on_desc">當鍵盤顯示時，無障礙服務會監聽音量鍵點擊，用於開始或停止語音識別。不監聽不穩定的音量鍵長按。</string>
    <string name="feature_volume_key_status_toast_off_desc">音量鍵錄音開始和停止時不額外提示，現有錯誤提示不受影響。</string>
    <string name="feature_volume_key_status_toast_on_desc">使用音量鍵成功開始或停止錄音時，顯示短 Toast 提示。</string>
    <string name="feature_volume_key_stop_on_ime_hidden_off_desc">音量鍵錄音期間如果鍵盤消失，錄音會繼續，直到你手動停止。</string>
    <string name="feature_volume_key_stop_on_ime_hidden_on_desc">音量鍵錄音期間如果鍵盤消失，會自動停止錄音。</string>

    <!-- 懸浮球寫入文字相容性模式 -->
    <string name="feature_floating_write_compat_off_desc">使用標準無障礙 API 插入文字。適用於大多數應用程式。</string>
    <string name="feature_floating_write_compat_on_desc">針對目標應用程式，使用「全選+貼上」方法來避免背景預留位置文字污染。可能會暫時使用剪貼簿（盡力恢復）。適用於 Telegram 和抖音等應用程式。</string>

    <!-- 懸浮球識別結果僅寫入剪貼簿 -->
    <string name="feature_floating_write_paste_off_desc">識別結果透過無障礙 API 直接插入到輸入欄位中。</string>
    <string name="feature_floating_write_paste_on_desc">針對目標套件名稱，識別結果僅複製到剪貼簿，不自動插入。適用於直接插入無法正常運作的應用程式。</string>

    <!-- 前台保活 -->
    <string name="feature_floating_keep_alive_off_desc">不啟用前台服務，系統可能更容易回收背景程序。</string>
    <string name="feature_floating_keep_alive_on_desc">啟動前台服務並顯示常駐通知，強化背景保活能力。</string>
    <string name="feature_floating_keep_alive_privileged_off_desc">仍以一般方式啟動前台保活服務，部分系統可能限制背景拉起。</string>
    <string name="feature_floating_keep_alive_privileged_on_desc">透過 Shizuku 或 root 定期以 shell 權限拉起前台保活服務，提高穩定性。需要 Shizuku 授權或 root。</string>
</resources>
