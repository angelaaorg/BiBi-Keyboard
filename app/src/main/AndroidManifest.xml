<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- 经典蓝牙权限（仅在 Android 12 以下有效） -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- Android 12+ 运行时蓝牙连接权限（用于更稳定地选择通信设备）；缺失时功能会自动回退 -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" tools:ignore="MissingPermission" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 存储权限：用于剪贴板文件下载到 Download/BiBi 目录 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- 允许从本应用安装 APK（配合未知来源安装权限引导） -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ 针对数据同步/下载类型前台服务权限（兼容不存在时忽略） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" tools:ignore="NewApi" />
    <!-- Android 14+ 针对用户主动开启的悬浮球后台常驻服务用途（兼容不存在时忽略） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" tools:ignore="NewApi" />
    <!-- 申请电池优化白名单 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 悬浮球需要的系统悬浮窗权限（运行时在设置中授予） -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 通知权限,用于显示悬浮球语音识别状态 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 开机自启 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- 若通过 ADB 授权可写入 Secure 设置，用于尝试自动开启无障碍（普通应用默认不会授予） -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" tools:ignore="ProtectedPermissions" />
    <!-- Shizuku 权限：用于在已授权时以 shell 身份执行部分系统命令 -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <application
        android:name=".App"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:localeConfig="@xml/locale_config"
        android:theme="@style/Theme.ASRKeyboard"
        android:usesCleartextTraffic="true"
        tools:targetApi="tiramisu">

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.setup.OnboardingGuideActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 外部兼容跳转页 -->
        <activity
            android:name=".ui.settings.asr.AsrRecognitionSettingsActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name=".ui.ime.ImePickerTileService"
            android:exported="true"
            android:icon="@drawable/keyboard"
            android:label="@string/qs_tile_ime_picker"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".ime.AsrKeyboardService"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:theme="@style/Theme.ASRKeyboard.Ime"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>



        <!-- 悬浮球语音识别服务 -->
        <service
            android:name=".ui.floating.FloatingAsrService"
            android:exported="false" />

        <!-- 悬浮球前台保活服务 -->
        <service
            android:name=".ui.floating.FloatingKeepAliveService"
            android:exported="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="user_enabled_floating_keyboard_keep_alive" />
        </service>

        <!-- Shizuku / root 增强保活：周期性拉起前台保活服务 -->
        <service
            android:name=".ui.floating.PrivilegedKeepAliveJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false" />

        <!-- 模型下载/解压前台服务（支持并发任务） -->
        <service
            android:name=".ui.settings.asr.ModelDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- APK 更新下载服务 -->
        <service
            android:name=".ui.update.ApkDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 无障碍服务,用于文本插入 -->
        <service
            android:name=".ui.AsrAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 开机启动接收器：根据偏好启动悬浮服务，并在具备权限时尝试开启无障碍 -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider: 分享调试日志（缓存目录） -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Shizuku Provider：用于接收 Shizuku Binder 并启用 API 调用 -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:exported="true"
            android:multiprocess="false" />

        <service
            android:name=".api.ExternalSpeechService"
            android:exported="true" />

        <service
            android:name=".api.FxliangFcitxVoiceInputProviderService"
            android:label="@string/fxliang_fcitx_voice_input_provider_label"
            android:exported="true">
            <intent-filter>
                <action android:name="${applicationId}.plugin.VOICE_INPUT" />
            </intent-filter>
            <intent-filter>
                <action android:name="org.fcitx.fcitx5.android.plugin.VOICE_INPUT" />
            </intent-filter>
            <intent-filter>
                <action android:name="org.fcitx.fcitx5.android.debug.plugin.VOICE_INPUT" />
            </intent-filter>
        </service>

        <!-- Android 标准语音识别服务 (RecognitionService) -->
        <service
            android:name=".api.AsrRecognitionService"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>

    </application>


    <queries>
        <package android:name="moe.shizuku.manager" />
        <package android:name="moe.shizuku.privileged.api" />
        <intent>
            <action android:name="android.view.InputMethod" />
        </intent>
    </queries>
    
</manifest>
